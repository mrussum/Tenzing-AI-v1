# Required for AI features (app works without this — AI panels will show unavailable)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required — set a strong random string in production
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production

# Optional — defaults to SQLite (./decisions.db) if not set
# For production on Render, set this to your PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated list of allowed frontend origins
# For Vercel deployment: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
